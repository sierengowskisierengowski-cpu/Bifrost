{
  "heimdall_version": "0.1.0",
  "schema_version": "1.0.0",
  "hardware_tier": "TIER_3",
  "use_local_llm": true,
  "use_extractor": true,
  "local_url": "http://127.0.0.1:11434/v1",
  "analyst_model": "qwen2.5:1.5b-instruct",
  "extractor_model": "qwen2.5:1.5b-instruct",
  "llm_timeout_seconds": 30.0,
  "llm_temperature": 0.0,
  "llm_num_ctx": 1024,
  "llm_num_predict": 64,
  "llm_num_gpu": 0,
  "learning_mode": true,
  "dry_run": true,
  "autonomous_actions_enabled": false,
  "dashboard_enabled": true,
  "dashboard_host": "127.0.0.1",
  "dashboard_port": 8766,
  "paths": {
    "config_path": "/etc/heimdall",
    "db_path": "/var/lib/heimdall/events.db",
    "log_path": "/var/log/heimdall"
  },
  "system_baseline": "You are Heimdall-Core. Analyze security telemetry. Output JSON only. Temperature 0.0."
}
